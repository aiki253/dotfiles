# # 新しい設定を読み込んでからインデックスを再構築する
# killall mds > /dev/null 2>&1
# # メインボリュームのインデックス作成が有効であることを確認する
# sudo mdutil -i on / > /dev/null
# # インデックスをゼロから再構築する
# sudo mdutil -E / > /dev/null

###############################################################################
# Terminal & iTerm 2                                                          #
###############################################################################

# Terminal.app で UTF-8 のみ使用する
defaults write com.apple.terminal StringEncodings -array 4

# Terminal.app のデフォルトテーマを Solarized Dark の改変版にする
# osascript <<EOD

